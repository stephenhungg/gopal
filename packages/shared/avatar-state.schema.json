{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GopalAvatarState",
  "additionalProperties": false,
  "type": "object",
  "required": ["mood", "gesture", "glowColor"],
  "properties": {
    "mood": {
      "type": "string",
      "enum": ["idle", "listening", "thinking", "speaking", "excited", "warning"]
    },
    "gesture": {
      "type": "string",
      "enum": ["still", "bob", "lean", "point", "shake", "laugh"]
    },
    "glowColor": {
      "type": "string",
      "pattern": "^#([A-Fa-f0-9]{6}|[A-Fa-f0-9]{3})$"
    },
    "caption": {
      "type": "string",
      "maxLength": 160
    }
  }
}
